# FlowTrace -- Environment Variables
# ====================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ====================================

# Flask secret key (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Flask environment: "production" or "development"
FLASK_ENV=production

# Supabase PostgreSQL connection string
# IMPORTANT: Use postgresql:// NOT postgres:// (SQLAlchemy requirement)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase API (for keepalive GitHub Action)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Jenkins connection
JENKINS_URL=http://localhost:8080
JENKINS_USERNAME=your-jenkins-username
JENKINS_TOKEN=your-jenkins-api-token

# App settings
DEMO_MODE=false
FLOWTRACE_AUTH_ENABLED=true

# Admin user password (used by init_db.py)
ADMIN_PASSWORD=Admin@FlowTrace2025
