{
  "version": 2,
  "builds": [
    {
      "src": "src/main/python/api/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "src/main/python/api/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "src/main/python/api/app.py"
    }
  ]
}
